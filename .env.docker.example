# See wiki/dotenv-docker-secret.md

# Docker image registry prefix.
# Default (university network): harbor cache proxy — avoids Docker Hub rate limits.
# Outside university: set to empty to pull directly from Docker Hub.
# REGISTRY_PREFIX=
REGISTRY_PREFIX=harbor.pg.innopolis.university/docker-hub-cache/

# backend
BACKEND_NAME="Learning Management Service"
BACKEND_DEBUG=false
BACKEND_RELOAD=false
BACKEND_CONTAINER_ADDRESS=0.0.0.0
BACKEND_CONTAINER_PORT=8000
BACKEND_HOST_ADDRESS=127.0.0.1
BACKEND_HOST_PORT=42001
BACKEND_ENABLE_INTERACTIONS=true
BACKEND_ENABLE_LEARNERS=true

# postgres
POSTGRES_DB=db-lab-7
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=42004

# pgadmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_HOST_ADDRESS=127.0.0.1
PGADMIN_HOST_PORT=42003

# caddy
CADDY_CONTAINER_PORT=80

# LMS API
LMS_API_HOST_ADDRESS=0.0.0.0
LMS_API_HOST_PORT=42002
LMS_API_KEY=my-secret-api-key

# Qwen Code API
QWEN_CODE_API_URL=http://qwen-code-api:8080
QWEN_CODE_API_HOST_PORT=42005

# Autochecker API credentials for the ETL pipeline
AUTOCHECKER_API_URL=https://auche.namaz.live
AUTOCHECKER_API_LOGIN=<autochecker-api-login>
AUTOCHECKER_API_PASSWORD=<autochecker-api-password>

# Bot (Task 4 - Docker deployment)
# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=your-telegram-bot-token-here
# LMS API key - must match LMS_API_KEY above
LMS_API_KEY=my-secret-api-key
# LLM API key - must match Qwen Code API key in qwen-code-api/.env.secret
LLM_API_KEY=your-qwen-api-key-here
# LLM model name (optional, defaults to coder-model)
LLM_API_MODEL=coder-model

# ---

# Constants that shouldn't be changed.
# Written here for convenient referencing in docs.
CONST_POSTGRESQL_SERVICE_NAME=postgres
CONST_POSTGRESQL_SERVER_NAME=postgres-lab-7
CONST_POSTGRESQL_DEFAULT_PORT=5432
CONST_PGADMIN_CONTAINER_PORT=80
